@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Esqueci Minha Senha";
}

<div class="position-relative login-page">
    <div class="overlay"></div>

    <div class="container position-relative z-1">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="glass-card p-5 animate__animated animate__fadeInUp">
                    <div class="text-center mb-4">
                        <i class="fas fa-key icon-glow"></i>
                        <h2 class="text-white fw-bold">Esqueceu sua senha?</h2>
                        <p class="text-white-50">Informe seu e-mail para receber o link de redefinicao.</p>
                    </div>

                    <form method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control custom-input"
                                   autocomplete="email"
                                   placeholder="Email" />
                            <label asp-for="Input.Email">Email</label>
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small d-block mb-4"></span>

                        <button type="submit" class="btn-login">
                            Enviar link <i class="fas fa-paper-plane ms-2"></i>
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-white-50 mb-0">
                            Lembrou sua senha?
                            <a asp-page="./Login" class="text-warning fw-bold text-decoration-none">
                                Entrar
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
