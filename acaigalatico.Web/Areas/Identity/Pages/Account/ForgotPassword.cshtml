@page "/ForgotPassword"
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar Senha";
}

<div class="position-relative login-page">
    <div class="overlay"></div>

    <div class="container position-relative z-1">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="glass-card p-5 animate__animated animate__fadeInUp">
                    
                    <div class="text-center mb-4">
                        <i class="fas fa-key icon-glow"></i>
                        <h2 class="text-white fw-bold">RECUPERE SUA SENHA</h2>
                        
                        @if (string.IsNullOrEmpty(Model.EmailMascarado) && Model.Etapa == 0)
                        {
                            <p class="text-white-50 mt-3">Email não identificado ou não encontrado. Por favor, tente o login primeiro.</p>
                        }
                    </div>

                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <input type="hidden" name="etapaInformada" value="@Model.Etapa" />

                        @if (!string.IsNullOrEmpty(Model.EmailMascarado))
                        {
                            @if (Model.Etapa == 1)
                            {
                                <!-- ETAPA 1: CONFIRMAÇÃO DE EMAIL -->
                                <div class="text-center mb-4">
                                    <p class="text-white-50">Se este for seu email:</p>
                                    <h4 class="text-white fw-bold">@Model.EmailMascarado</h4>
                                </div>

                                <button type="submit" class="btn-login">
                                    Confirmar <i class="fas fa-check-circle ms-2"></i>
                                </button>
                            }
                            else if (Model.Etapa == 2)
                            {
                                <!-- ETAPA 2: VALIDAÇÃO DE NOME -->
                                <div class="text-center mb-3">
                                    <p class="text-white-50">Se este for seu email: @Model.EmailMascarado</p>
                                    <p class="text-white mt-3">Por favor, informe seu nome completo para validar:</p>
                                </div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Nome" class="form-control custom-input" placeholder="Nome completo" required autocomplete="off" />
                                    <label asp-for="Input.Nome">Nome completo</label>
                                </div>

                                <button type="submit" class="btn-login">
                                    Continuar <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            }
                        }

                        <div class="text-center mt-4">
                            <a asp-page="./Login" class="link-light small">
                                <i class="fas fa-undo me-1"></i> Voltar para o login
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
