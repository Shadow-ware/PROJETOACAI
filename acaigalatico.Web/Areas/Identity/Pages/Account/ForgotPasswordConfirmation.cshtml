@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Email Enviado";
}

<div class="position-relative login-page">
    <div class="overlay"></div>

    <div class="container position-relative z-1">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="glass-card p-5 animate__animated animate__fadeInUp">
                    <div class="text-center">
                        <i class="fas fa-envelope-open-text icon-glow"></i>
                        <h2 class="text-white fw-bold">Confira seu email</h2>
                        <p class="text-white-50 mb-4">
                            Se existir uma conta com o email informado, enviaremos um link para redefinir sua senha.
                        </p>

                        <a asp-page="./Login" class="btn-login d-inline-block text-decoration-none">
                            Voltar para login <i class="fas fa-arrow-left ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
