@page "/ResetPassword"
@model ResetPasswordModel
@{
    ViewData["Title"] = "Nova Senha";
}

<div class="position-relative login-page">
    <div class="overlay"></div>

    <div class="container position-relative z-1">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="glass-card p-5 animate__animated animate__fadeInUp">
                    
                    <div class="text-center mb-4">
                        <i class="fas fa-lock icon-glow"></i>
                        <h2 class="text-white fw-bold">NOVA SENHA</h2>
                        <p class="text-white-50">Escolha sua nova senha de acesso</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" type="password" class="form-control custom-input" placeholder="Nova senha" required />
                            <label asp-for="Input.Password">Nova senha</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" type="password" class="form-control custom-input" placeholder="Confirmar senha" required />
                            <label asp-for="Input.ConfirmPassword">Confirmar senha</label>
                        </div>

                        <button type="submit" class="btn-login">
                            Alterar Senha <i class="fas fa-check ms-2"></i>
                        </button>

                        <div class="text-center mt-3">
                            <a asp-page="./Login" class="link-light small">
                                Cancelar e voltar
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
