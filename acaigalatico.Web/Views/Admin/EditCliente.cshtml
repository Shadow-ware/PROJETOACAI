@model acaigalatico.Domain.Entities.Cliente
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Editar Cliente";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold m-0">Editar Cliente #@Model.Id</h5>
        <a asp-action="Clientes" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Voltar</a>
    </div>

    <form asp-action="EditCliente" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nome" class="form-label">Nome</label>
                <input asp-for="Nome" class="form-control rounded-pill" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Telefone" class="form-label">Telefone</label>
                <input asp-for="Telefone" class="form-control rounded-pill" />
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>
            <div class="col-12 mt-4">
                <button type="submit" class="btn btn-primary rounded-pill px-4">Salvar Alterações</button>
            </div>
        </div>
    </form>
</div>
