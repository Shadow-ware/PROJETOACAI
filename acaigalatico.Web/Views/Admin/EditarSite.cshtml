@model acaigalatico.Domain.Entities.ConteudoInicio
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Editar Página Inicial";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="fw-bold m-0"><i class="fas fa-home me-2 text-primary"></i> Editor Dinâmico: Página Inicial</h5>
            <small class="text-muted">Personalize absolutamente tudo o que aparece na sua Home</small>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="EditarSite" method="post" enctype="multipart/form-data">
        <!-- SEÇÃO HERO (TOPO) -->
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-rocket me-2"></i> 1. Topo do Site (Hero Section)</h6>
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Título Principal</label>
                    <input asp-for="Titulo" class="form-control rounded-3" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Subtítulo</label>
                    <input asp-for="Subtitulo" class="form-control rounded-3" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Imagem de Fundo (Upload)</label>
                    <input type="file" name="heroFile" class="form-control rounded-3" accept="image/*" onchange="previewImage(this, 'heroPreview')" />
                    <input type="hidden" asp-for="ImagemUrl" />
                </div>
                <div class="col-md-6 text-center">
                    <div class="preview-container bg-light rounded-3 overflow-hidden d-inline-block" style="width: 100%; height: 120px; border: 1px solid #eee;">
                        <img id="heroPreview" src="@Model.ImagemUrl" class="w-100 h-100" style="object-fit: cover;" onerror="this.src='/images/logo-sem-escrita.png'" />
                    </div>
                </div>
            </div>
        </div>

        <!-- SEÇÃO QUEM SOMOS -->
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-users me-2"></i> 2. Seção "Quem Somos"</h6>
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Título da Seção</label>
                    <input asp-for="SobreTitulo" class="form-control rounded-3" required />
                    
                    <label class="form-label fw-bold small mt-3">Descrição Detalhada</label>
                    <textarea asp-for="SobreDescricao" class="form-control rounded-3" rows="5" required></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Imagem Lateral (Upload)</label>
                    <input type="file" name="sobreImgFile" class="form-control rounded-3 mb-2" accept="image/*" onchange="previewImage(this, 'sobrePreview')" />
                    <input type="hidden" asp-for="SobreImagemUrl" />
                    <div class="preview-container bg-light rounded-3 overflow-hidden" style="width: 100%; height: 180px; border: 1px solid #eee;">
                        <img id="sobrePreview" src="@Model.SobreImagemUrl" class="w-100 h-100" style="object-fit: cover;" onerror="this.src='/images/entrada-acai.jpeg'" />
                    </div>
                </div>
            </div>
            <hr class="my-4">
            <h6 class="fw-bold text-muted mb-3 small">Ícones de Destaque (Features)</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small">Feature 1 (Verde)</label>
                    <input asp-for="Feature1" class="form-control form-control-sm rounded-3" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Feature 2 (Amarelo)</label>
                    <input asp-for="Feature2" class="form-control form-control-sm rounded-3" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Feature 3 (Vermelho)</label>
                    <input asp-for="Feature3" class="form-control form-control-sm rounded-3" required />
                </div>
            </div>
        </div>

        <!-- SEÇÃO EXPOSIÇÃO -->
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-images me-2"></i> 3. Seção Exposição de Açaís (Cards)</h6>
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Título da Seção</label>
                    <input asp-for="ExpoTitulo" class="form-control rounded-3" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Subtítulo da Seção</label>
                    <input asp-for="ExpoSubtitulo" class="form-control rounded-3" required />
                </div>
            </div>

            <div class="row g-3">
                @for (int i = 0; i < Model.ItensExposicao.Count; i++)
                {
                    <div class="col-md-4">
                        <div class="p-3 border rounded-4 bg-light">
                            <label class="form-label fw-bold small text-primary">Card @(i + 1)</label>
                            <input asp-for="ItensExposicao[i].Nome" class="form-control form-control-sm rounded-3 mb-2" placeholder="Nome do Açaí" required />
                            
                            <div class="mb-2 text-center">
                                <img id="itemPreview_@i" src="@Model.ItensExposicao[i].ImagemUrl" class="rounded-3 shadow-sm" style="width: 100%; height: 120px; object-fit: cover;" onerror="this.src='/images/logo-sem-escrita.png'">
                            </div>
                            
                            <input type="file" name="itemFiles" class="form-control form-control-sm rounded-3" accept="image/*" onchange="previewImage(this, 'itemPreview_@i')" />
                            <input type="hidden" asp-for="ItensExposicao[i].ImagemUrl" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SEÇÃO OUTROS PRODUTOS E WHATSAPP -->
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-plus-circle me-2"></i> 4. Outros Produtos e WhatsApp</h6>
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Título "Outros Produtos"</label>
                    <input asp-for="OutrosTitulo" class="form-control rounded-3 mb-3" required />
                    
                    <label class="form-label fw-bold small">Texto Destaque (Card)</label>
                    <input asp-for="OutrosTextoDestaque" class="form-control rounded-3 mb-3" required />

                    <label class="form-label fw-bold small">Imagem Outros Produtos (Upload)</label>
                    <input type="file" name="outrosImgFile" class="form-control rounded-3 mb-2" accept="image/*" onchange="previewImage(this, 'outrosPreview')" />
                    <input type="hidden" asp-for="OutrosImagemUrl" />
                    <div class="preview-container bg-light rounded-3 overflow-hidden" style="width: 100%; height: 150px; border: 1px solid #eee;">
                        <img id="outrosPreview" src="@Model.OutrosImagemUrl" class="w-100 h-100" style="object-fit: cover;" onerror="this.src='/images/produtos.jpg'" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">Texto do Botão WhatsApp</label>
                    <input asp-for="WhatsAppTexto" class="form-control rounded-3 mb-3" required />

                    <label class="form-label fw-bold small">Subtítulo WhatsApp</label>
                    <input asp-for="WhatsAppSubtitulo" class="form-control rounded-3 mb-3" required />

                    <label class="form-label fw-bold small">Link/Número WhatsApp</label>
                    <input asp-for="WhatsAppLink" class="form-control rounded-3" required />
                    <small class="text-muted">Formato: https://wa.me/5511982599249</small>
                </div>
            </div>
        </div>

        <div class="col-12 text-end mb-5">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow animate__animated animate__pulse animate__infinite">
                <i class="fas fa-sync-alt me-2"></i> PUBLICAR TODAS AS ALTERAÇÕES
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
