@model acaigalatico.Web.ViewModels.PerfilViewModel
@{
    ViewData["Title"] = "Meu Perfil";
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card p-4 p-md-5">
                <div class="d-flex align-items-center mb-4 border-bottom border-white-10 pb-3">
                    <div class="bg-warning rounded-circle p-3 me-3">
                        <i class="fas fa-user-edit text-dark fs-4"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">Configurações de Perfil</h2>
                        <p class="text-white-50 mb-0">Gerencie suas informações e foto de perfil</p>
                    </div>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 mb-4" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Update" method="post" enctype="multipart/form-data" id="profileForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-4">
                        <!-- Seção Foto -->
                        <div class="col-lg-4 text-center border-end border-white-10">
                            <div class="mb-4">
                                <h5 class="fw-bold mb-3 text-start">Foto de Perfil</h5>
                                <div class="position-relative d-inline-block">
                                    <img id="imgPreview" 
                                         src="@(string.IsNullOrWhiteSpace(Model.CurrentPhotoUrl) ? "/images/logo-sem-escrita.png" : Model.CurrentPhotoUrl)" 
                                         class="rounded-circle border border-4 border-white-10 shadow-lg" 
                                         style="width: 180px; height: 180px; object-fit: cover;">
                                    <label for="Photo" class="btn btn-sm btn-warning rounded-circle position-absolute bottom-0 end-0 p-2 shadow" style="cursor: pointer;">
                                        <i class="fas fa-camera"></i>
                                    </label>
                                </div>
                                <input type="file" asp-for="Photo" class="d-none" accept="image/png, image/jpeg, image/jpg" onchange="previewImage(this)">
                                <div class="mt-3">
                                    <small class="text-white-50 d-block">Formatos: JPG, PNG</small>
                                    <span asp-validation-for="Photo" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Seção Dados e Endereço -->
                        <div class="col-lg-8">
                            <!-- Dados Pessoais -->
                            <div class="mb-5">
                                <h5 class="fw-bold mb-4 text-warning"><i class="fas fa-id-card me-2"></i> Dados Pessoais</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="NewUserName" class="form-label text-white-50 small fw-bold uppercase">Nome Completo</label>
                                        <input asp-for="NewUserName" class="form-control form-control-glass" placeholder="Ex: João Silva">
                                        <span asp-validation-for="NewUserName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="NewEmail" class="form-label text-white-50 small fw-bold uppercase">E-mail</label>
                                        <input asp-for="NewEmail" class="form-control form-control-glass" placeholder="email@exemplo.com">
                                        <span asp-validation-for="NewEmail" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Telefone" class="form-label text-white-50 small fw-bold uppercase">Telefone</label>
                                        <input asp-for="Telefone" class="form-control form-control-glass phone-mask" placeholder="(00) 00000-0000">
                                        <span asp-validation-for="Telefone" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Endereço -->
                            <div class="mb-5">
                                <h5 class="fw-bold mb-4 text-warning"><i class="fas fa-map-marker-alt me-2"></i> Endereço</h5>
                                <div class="row g-3">
                                    <div class="col-md-9">
                                        <label asp-for="Rua" class="form-label text-white-50 small fw-bold uppercase">Rua / Logradouro</label>
                                        <input asp-for="Rua" class="form-control form-control-glass" placeholder="Nome da rua">
                                    </div>
                                    <div class="col-md-3">
                                        <label asp-for="Numero" class="form-label text-white-50 small fw-bold uppercase">Número</label>
                                        <input asp-for="Numero" class="form-control form-control-glass" placeholder="Nº">
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Bairro" class="form-label text-white-50 small fw-bold uppercase">Bairro</label>
                                        <input asp-for="Bairro" class="form-control form-control-glass" placeholder="Seu bairro">
                                    </div>
                                    <div class="col-md-5">
                                        <label asp-for="Cidade" class="form-label text-white-50 small fw-bold uppercase">Cidade</label>
                                        <input asp-for="Cidade" class="form-control form-control-glass" placeholder="Sua cidade">
                                    </div>
                                    <div class="col-md-3">
                                        <label asp-for="Cep" class="form-label text-white-50 small fw-bold uppercase">CEP</label>
                                        <input asp-for="Cep" class="form-control form-control-glass cep-mask" placeholder="00000-000">
                                        <span asp-validation-for="Cep" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Segurança -->
                            <div class="mb-4">
                                <h5 class="fw-bold mb-4 text-warning"><i class="fas fa-lock me-2"></i> Alterar Senha</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="CurrentPassword" class="form-label text-white-50 small fw-bold uppercase">Senha Atual</label>
                                        <input type="password" asp-for="CurrentPassword" class="form-control form-control-glass" placeholder="••••••••">
                                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="NewPassword" class="form-label text-white-50 small fw-bold uppercase">Nova Senha</label>
                                        <input type="password" asp-for="NewPassword" class="form-control form-control-glass" placeholder="Mínimo 4 caracteres">
                                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 border-white-10">

                    <div class="d-flex justify-content-end gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold" id="btnSubmit">
                            <span id="btnText">Salvar Alterações 💾</span>
                            <span id="btnLoading" class="spinner-border spinner-border-sm d-none" role="status"></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.phone-mask').mask('(00) 00000-0000');
            $('.cep-mask').mask('00000-000');

            $('#profileForm').on('submit', function () {
                if ($(this).valid()) {
                    $('#btnSubmit').prop('disabled', true);
                    $('#btnText').text('Salvando...');
                    $('#btnLoading').removeClass('d-none');
                }
            });
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        color: white;
    }

    .form-control-glass {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }

    .form-control-glass:focus {
        background: rgba(255, 255, 255, 0.1) !important;
        border-color: #f1c40f !important;
        box-shadow: 0 0 0 0.25rem rgba(241, 196, 15, 0.25) !important;
    }

    .border-white-10 {
        border-color: rgba(255, 255, 255, 0.1) !important;
    }

    .uppercase {
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>
