@model IEnumerable<acaigalatico.Domain.Entities.Venda>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Pedidos";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold m-0">Gestão de Pedidos</h5>
            <small class="text-muted">Visualize e gerencie as solicitações dos clientes</small>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createPedidoModal">
            <i class="fas fa-plus me-2"></i> Novo Pedido
        </button>
    </div>

    <!-- Modal Create Pedido -->
    <div class="modal fade" id="createPedidoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: #2c3e50; color: #fff;">
                <div class="modal-header border-0">
                    <h5 class="modal-title"><i class="fas fa-plus-circle me-2 text-success"></i> Novo Pedido</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="CreatePedido" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label text-white-50">Cliente</label>
                            <select class="form-select auth-input" name="clienteId">
                                <option value="">Cliente Avulso</option>
                                @foreach (var c in (IEnumerable<Cliente>)ViewBag.Clientes)
                                {
                                    <option value="@c.Id">@c.Nome</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Valor Total (R$)</label>
                            <input class="form-control auth-input" name="valorTotal" placeholder="0,00" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Status</label>
                            <select class="form-select auth-input" name="status">
                                @foreach (var s in Enum.GetNames(typeof(StatusVenda)))
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Endereço</label>
                            <input class="form-control auth-input" name="endereco" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Bairro</label>
                            <input class="form-control auth-input" name="bairro" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Observação</label>
                            <textarea class="form-control auth-input" name="observacao"></textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Criar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-admin">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th>Cliente</th>
                    <th>Total</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in Model)
                {
                    <tr>
                        <td class="fw-bold">#@pedido.Id</td>
                        <td>@pedido.DataVenda.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                string badgeClass = pedido.Status switch {
                                    StatusVenda.Pendente => "bg-warning text-dark",
                                    StatusVenda.Preparando => "bg-info",
                                    StatusVenda.SaiuParaEntrega => "bg-primary",
                                    StatusVenda.Entregue => "bg-success",
                                    StatusVenda.Cancelado => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge rounded-pill @badgeClass">@pedido.Status</span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm bg-light rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                                    <i class="fas fa-user text-muted" style="font-size: 0.8rem;"></i>
                                </div>
                                @(pedido.Cliente?.Nome ?? "Cliente Avulso")
                            </div>
                        </td>
                        <td class="fw-bold text-success">R$ @(pedido.ValorTotal.ToString("0.00").Replace('.', ','))</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-light rounded-circle text-primary me-1" title="Editar" data-bs-toggle="modal" data-bs-target="#editPedido_@pedido.Id">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form asp-action="DeletePedido" asp-route-id="@pedido.Id" method="post" class="d-inline" onsubmit="return confirm('Deseja realmente excluir este pedido?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light rounded-circle text-danger" title="Excluir">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>

                            <div class="modal fade" id="editPedido_@pedido.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content" style="background: #2c3e50; color: #fff;">
                                        <div class="modal-header border-0">
                                            <h5 class="modal-title"><i class="fas fa-edit me-2 text-warning"></i> Editar Pedido</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <form asp-action="EditPedido" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@pedido.Id" />
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Cliente</label>
                                                    <select class="form-select auth-input" name="clienteId">
                                                        <option value="">Cliente Avulso</option>
                                                        @foreach (var c in (IEnumerable<Cliente>)ViewBag.Clientes)
                                                        {
                                                            <option value="@c.Id" selected="@(pedido.ClienteId == c.Id)">@c.Nome</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Valor Total</label>
                                                    <input class="form-control auth-input" name="valorTotal" value="@pedido.ValorTotal.ToString("F2")" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Status</label>
                                                    <select class="form-select auth-input" name="status">
                                                        @foreach (var s in Enum.GetNames(typeof(StatusVenda)))
                                                        {
                                                            <option value="@s" selected="@(pedido.Status.ToString()==s)">@s</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Endereço</label>
                                                    <input class="form-control auth-input" name="enderecoEntrega" value="@pedido.EnderecoEntrega" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Bairro</label>
                                                    <input class="form-control auth-input" name="bairroEntrega" value="@pedido.BairroEntrega" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-white-50">Observação</label>
                                                    <textarea class="form-control auth-input" name="observacao">@pedido.Observacao</textarea>
                                                </div>
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                                                    <button type="submit" class="btn btn-primary rounded-pill px-4">Salvar</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
