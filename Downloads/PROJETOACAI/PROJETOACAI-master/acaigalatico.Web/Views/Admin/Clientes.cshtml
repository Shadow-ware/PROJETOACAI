@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
<!-- 🔥 Alterado de Cliente para IdentityUser para usar usuários reais -Nicolas -->
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Gestão de Clientes";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold m-0">Gestão de Clientes</h5>
            <small class="text-muted">Usuários cadastrados no sistema</small>
            <!-- 🔥 Texto ajustado -Nicolas -->
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            <!-- 🔥 Corrigido data-bs-dismiss -Nicolas -->
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-admin">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Usuário</th> <!-- 🔥 Antes era Nome -Nicolas -->
                    <th>Email</th> <!-- 🔥 Novo campo -Nicolas -->
                    <th class="text-end">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <!-- 🔥 Alterado de cliente para user -Nicolas -->

                    <tr>
                        <td class="fw-bold">#@user.Id</td>

                        <td>
                            @user.UserName
                            <!-- 🔥 Substitui cliente.Nome -Nicolas -->
                        </td>

                        <td>
                            @user.Email
                            <!-- 🔥 Novo campo exibido -Nicolas -->
                        </td>

                        <td class="text-end">
                            <form asp-action="ExcluirUsuario" method="post" class="d-inline"
                                  onsubmit="return confirm('Deseja realmente excluir este usuário?')">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@user.Id" />
                                <!-- 🔥 Usa ID do IdentityUser -Nicolas -->

                                <button type="submit" class="btn btn-sm btn-light rounded-circle text-danger" title="Excluir">
                                    <i class="fas fa-trash"></i>
                                </button>
                                <!-- 🔥 Agora chama ExcluirUsuario -Nicolas -->
                            </form>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>