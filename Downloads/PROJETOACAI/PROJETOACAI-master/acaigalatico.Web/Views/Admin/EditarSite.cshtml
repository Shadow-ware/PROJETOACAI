@model IEnumerable<acaigalatico.Domain.Entities.SiteContent>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Editar Site (Front-end)";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h5 class="fw-bold m-0"><i class="fas fa-edit me-2 text-primary"></i> Editar Conteúdo do Site</h5>
            <small class="text-muted">Gerencie textos, imagens e descrições exibidas aos clientes</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <form asp-action="SeedMockData" method="post" onsubmit="return confirm('Isso irá resetar os textos do site para o padrão. Continuar?')">
                <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                    <i class="fas fa-sync-alt me-1"></i> Resetar Páginas
                </button>
            </form>
            <div class="nav-pills-admin d-flex gap-2" id="v-pills-tab" role="tablist">
                <button class="btn btn-sm btn-outline-primary active rounded-pill px-3" id="pills-inicio-tab" data-bs-toggle="pill" data-bs-target="#pills-inicio" type="button">Início</button>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" id="pills-cardapio-tab" data-bs-toggle="pill" data-bs-target="#pills-cardapio" type="button">Cardápio</button>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" id="pills-pedido-tab" data-bs-toggle="pill" data-bs-target="#pills-fazerpedido" type="button">Pedido</button>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" id="pills-contato-tab" data-bs-toggle="pill" data-bs-target="#pills-contato" type="button">Contato</button>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <p class="text-muted">Nenhuma página encontrada. Clique no botão "Resetar Páginas" para inicializar o conteúdo.</p>
        </div>
    }

    <div class="tab-content mt-4" id="pills-tabContent">
        @if (Model != null && Model.Any())
        {
            @foreach (var pageGroup in Model.GroupBy(c => c.Page ?? "Outros"))
            {
                <div class="tab-pane fade @(pageGroup.Key == "Inicio" ? "show active" : "")" id="pills-@pageGroup.Key.ToLower().Replace(" ", "")" role="tabpanel">
                    <div class="row g-4">
                        @foreach (var content in pageGroup)
                        {
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-light">
                                    <form asp-action="UpdateSiteContent" method="post" enctype="multipart/form-data">
                                        <input type="hidden" name="key" value="@content.Key" />
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-muted small text-uppercase">@content.Key.Replace("_", " ")</label>
                                            
                                            @if (content.Type == "Text")
                                            {
                                                <input type="text" name="value" class="form-control rounded-3 border-0 shadow-sm" value="@content.Value" />
                                            }
                                            else if (content.Type == "Description")
                                            {
                                                <textarea name="value" class="form-control rounded-3 border-0 shadow-sm" rows="4">@content.Value</textarea>
                                            }
                                            else if (content.Type == "Image")
                                            {
                                                <div class="d-flex flex-column gap-2">
                                                    <input type="text" name="value" class="form-control rounded-3 border-0 shadow-sm" value="@content.Value" />
                                                    <input type="file" name="file" class="form-control rounded-3 border-0 shadow-sm" accept="image/*" />
                                                    <small class="text-muted">URL ou Caminho (ex: /images/banner.png)</small>
                                                    <div class="preview-img border rounded-3 p-1 bg-white shadow-sm align-self-start" style="width: 120px; height: 120px;">
                                                        <img src="@content.Value" alt="Preview" class="w-100 h-100 rounded-2" style="object-fit: cover;" onerror="this.src='/images/default-acai.png'" />
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="text-end mt-auto">
                                            <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm">
                                                <i class="fas fa-save me-1"></i> Salvar
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
