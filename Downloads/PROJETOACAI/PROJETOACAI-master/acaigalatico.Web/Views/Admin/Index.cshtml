@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Dashboard";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <a asp-action="EditMetrics" class="text-decoration-none text-dark h-100 d-block">
            <div class="admin-card p-4 d-flex align-items-center h-100">
                <div class="stat-icon bg-gradient-purple me-3">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div>
                    <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Vendas Hoje <i class="fas fa-edit ms-1 text-primary"></i></small>
                    <h3 class="m-0 fw-bold">@ViewBag.VendasHoje</h3>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="EditMetrics" class="text-decoration-none text-dark h-100 d-block">
            <div class="admin-card p-4 d-flex align-items-center h-100">
                <div class="stat-icon bg-gradient-blue me-3">
                    <i class="fas fa-users"></i>
                </div>
                <div>
                    <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Total Clientes <i class="fas fa-edit ms-1 text-primary"></i></small>
                    <h3 class="m-0 fw-bold">@ViewBag.TotalClientes</h3>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="EditMetrics" class="text-decoration-none text-dark h-100 d-block">
            <div class="admin-card p-4 d-flex align-items-center h-100">
                <div class="stat-icon bg-gradient-green me-3">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div>
                    <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Faturamento <i class="fas fa-edit ms-1 text-primary"></i></small>
                    <h3 class="m-0 fw-bold">@(((decimal)ViewBag.Faturamento).ToString("C"))</h3>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="admin-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0">Vendas dos Últimos 7 Dias</h5>
                <a asp-action="EditChart" class="btn btn-sm btn-outline-primary rounded-pill"><i class="fas fa-chart-line me-1"></i> Configurar Gráfico</a>
            </div>
            <canvas id="salesChart" height="120"></canvas>
        </div>
    </div>
    <div class="col-md-4">
        <div class="admin-card p-4">
            <h5 class="fw-bold mb-4">Vendas por Categoria</h5>
            <canvas id="categoryChart" height="250"></canvas>
        </div>
    </div>
</div>

@* Seção de "Últimos Pedidos" removida conforme solicitado *@

@section Scripts {
    <script>
        // Gráfico de Vendas Dinâmico
        const salesCtx = document.getElementById('salesChart').getContext('2d');
        const salesLabels = @Html.Raw(Json.Serialize(ViewBag.SalesLabels));
        const salesData = @Html.Raw(Json.Serialize(ViewBag.SalesData));

        new Chart(salesCtx, {
            type: 'line',
            data: {
                labels: salesLabels,
                datasets: [{
                    label: 'Vendas (R$)',
                    data: salesData,
                    borderColor: '#9b59b6',
                    backgroundColor: 'rgba(155, 89, 182, 0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'R$ ' + context.parsed.y.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                            }
                        }
                    }
                },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { color: '#f1f2f6' },
                        ticks: {
                            callback: function(value) {
                                return 'R$ ' + value;
                            }
                        }
                    },
                    x: { grid: { display: false } }
                }
            }
        });

        // Gráfico de Categorias
        const catCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(catCtx, {
            type: 'doughnut',
            data: {
                labels: ['Açaí', 'Bebidas', 'Salgados', 'Outros'],
                datasets: [{
                    data: [65, 15, 12, 8],
                    backgroundColor: ['#9b59b6', '#3498db', '#2ecc71', '#f1c40f'],
                    borderWidth: 0
                }]
            },
            options: {
                plugins: {
                    legend: { position: 'bottom' }
                },
                cutout: '70%'
            }
        });
    </script>
}
