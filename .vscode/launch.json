{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch acaigalatico.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build acaigalatico.Web",
      "program": "${workspaceFolder}/acaigalatico.Web/bin/Debug/net10.0/acaigalatico.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/acaigalatico.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5230",
        "DOTNET_SYSTEM_NET_QUIC_ENABLED": "0",
        "DOTNET_SYSTEM_NET_HTTP_SOCKETSHTTPHANDLER_HTTP3SUPPORT": "0"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
